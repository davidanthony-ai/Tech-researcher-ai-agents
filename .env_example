# Copy to .env and fill in your real values.
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Serper — Google search for SerperDevTool — https://serper.dev
SERPER_API_KEY=

# Optional — local model via Ollama (see CrewAI docs / LLM Connections)
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=openhermes
# OPENAI_API_KEY=sk-dummy

# Streamlit Community Cloud: set the same keys in the app Secrets (TOML), not in the repo.
# Local Streamlit: optional copy of .streamlit/secrets.toml.example → secrets.toml (gitignored).

# Optional — speed vs depth (CrewAI agent loop caps; defaults 7 / 5 if unset)
# CREW_RESEARCHER_MAX_ITER=7
# CREW_WRITER_MAX_ITER=5
